{
  "name": "sound-alerts",
  "displayName": "Sound Alerts",
  "description": "Audio cues for the Cursor agent: rings a bell when the agent finishes, via a Cursor `stop` hook the extension installs for you.",
  "version": "0.0.4",
  "publisher": "dshashikk",
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "cursor",
    "sound",
    "audio",
    "notification",
    "bell",
    "agent",
    "ai"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dshashikk/sound-alerts.git"
  },
  "bugs": {
    "url": "https://github.com/dshashikk/sound-alerts/issues"
  },
  "homepage": "https://github.com/dshashikk/sound-alerts#readme",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "scripts": {
    "package": "vsce package",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0",
    "ovsx": "^0.9.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "soundAlerts.testSounds",
        "title": "Sound Alerts: Test Sounds"
      },
      {
        "command": "soundAlerts.reinstallHook",
        "title": "Sound Alerts: Reinstall Hook"
      },
      {
        "command": "soundAlerts.removeHook",
        "title": "Sound Alerts: Remove Hook"
      }
    ],
    "configuration": {
      "title": "Sound Alerts",
      "properties": {
        "soundAlerts.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable sound alerts. When off, the Cursor stop hook is removed."
        },
        "soundAlerts.bellSound": {
          "type": "string",
          "default": "/System/Library/Sounds/Glass.aiff",
          "description": "Sound file played when the agent finishes (the stop hook)."
        },
        "soundAlerts.warningSound": {
          "type": "string",
          "default": "/System/Library/Sounds/Sosumi.aiff",
          "description": "Sound used by the Test Sounds command (and reserved for a future question alert)."
        },
        "soundAlerts.playerCommand": {
          "type": "string",
          "default": "afplay",
          "description": "Command used to play a sound file (macOS: afplay; Linux: paplay/aplay; Windows: powershell)."
        }
      }
    }
  }
}
